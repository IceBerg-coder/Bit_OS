#!/bin/sh
# bit-monitor: Live TUI system monitor for BitOS (v1.2)
# Usage: bit-monitor [interval_seconds]   Ctrl+C to exit
INTERVAL=${1:-2}
C0='\033[0m'; C1='\033[1;32m'; C2='\033[1;34m'; C3='\033[1;33m'; C4='\033[1;36m'; CR='\033[1;31m'

cpu_times() { awk '/^cpu / {print $2+$3+$4+$5+$6+$7+$8, $5}' /proc/stat; }

make_bar() {
    USED=$1; TOTAL=$2; WIDTH=${3:-20}
    [ "$TOTAL" -eq 0 ] && printf "[--------------------]" && return
    PCT=$(( USED * 100 / TOTAL ))
    FILLED=$(( PCT * WIDTH / 100 ))
    EMPTY=$(( WIDTH - FILLED ))
    BAR="["
    i=0; while [ $i -lt $FILLED ]; do BAR="${BAR}#"; i=$((i+1)); done
    i=0; while [ $i -lt $EMPTY ];  do BAR="${BAR}-"; i=$((i+1)); done
    printf "%s] %3d%%" "$BAR" "$PCT"
}

svc_badge() {
    NAME="$1"; PF="$2"
    if [ -n "$PF" ] && [ -f "$PF" ] && kill -0 "$(cat "$PF" 2>/dev/null)" 2>/dev/null; then
        printf "${C1}[running]${C0}"
    elif pidof "$NAME" >/dev/null 2>&1; then
        printf "${C1}[running]${C0}"
    else
        printf "${CR}[stopped]${C0}"
    fi
}

prev=$(cpu_times)
prev_total=$(echo "$prev" | awk '{print $1}')
prev_idle=$(echo "$prev"  | awk '{print $2}')

while true; do
    clear
    printf "${C1}╔════════════════════════════════════════════════╗${C0}\n"
    printf "${C1}║      BitOS Live System Monitor  (v1.2)         ║${C0}\n"
    printf "${C1}╚════════════════════════════════════════════════╝${C0}\n"
    printf "${C4}  %-40s interval: %ss  Ctrl+C to exit${C0}\n\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$INTERVAL"

    # ── CPU ──────────────────────────────────────────────────
    cur=$(cpu_times)
    cur_total=$(echo "$cur" | awk '{print $1}')
    cur_idle=$(echo "$cur"  | awk '{print $2}')
    diff_total=$(( cur_total - prev_total ))
    diff_idle=$(( cur_idle   - prev_idle  ))
    [ "$diff_total" -gt 0 ] && cpu_pct=$(( (diff_total - diff_idle) * 100 / diff_total )) || cpu_pct=0
    prev_total=$cur_total; prev_idle=$cur_idle
    CPU_BAR=$(make_bar $cpu_pct 100 24)
    printf "${C2}CPU:${C0}       %s\n" "$CPU_BAR"

    # ── Memory ───────────────────────────────────────────────
    mem_total=$(awk '/MemTotal/   {print $2}' /proc/meminfo)
    mem_avail=$(awk '/MemAvailable/{print $2}' /proc/meminfo)
    mem_used=$(( mem_total - mem_avail ))
    MEM_BAR=$(make_bar $mem_used $mem_total 24)
    printf "${C2}MEM:${C0}       %s  (%d/%d MB)\n" "$MEM_BAR" "$((mem_used/1024))" "$((mem_total/1024))"

    # ── Swap ─────────────────────────────────────────────────
    swap_total=$(awk '/SwapTotal/{print $2}' /proc/meminfo)
    swap_free=$(awk '/SwapFree/{print $2}'  /proc/meminfo)
    if [ "$swap_total" -gt 0 ]; then
        swap_used=$(( swap_total - swap_free ))
        SWP_BAR=$(make_bar $swap_used $swap_total 24)
        printf "${C2}SWAP:${C0}      %s  (%d/%d MB)\n" "$SWP_BAR" "$((swap_used/1024))" "$((swap_total/1024))"
    fi

    # ── Disk ─────────────────────────────────────────────────
    DISK_LINE=$(df -k / 2>/dev/null | awk 'NR==2{print}')
    if [ -z "$DISK_LINE" ]; then DISK_LINE=$(df -k /tmp 2>/dev/null | awk 'NR==2{print}'); fi
    if [ -n "$DISK_LINE" ]; then
        disk_total=$(echo "$DISK_LINE" | awk '{print $2}')
        disk_used=$(echo "$DISK_LINE"  | awk '{print $3}')
        disk_mp=$(echo "$DISK_LINE"    | awk '{print $6}')
        DISK_BAR=$(make_bar $disk_used $disk_total 24)
        printf "${C2}DISK(${disk_mp}):${C0} %s  (%d/%d MB)\n" "$DISK_BAR" "$((disk_used/1024))" "$((disk_total/1024))"
    fi
    LOAD=$(awk '{print $1, $2, $3}' /proc/loadavg)
    PROCS=$(awk '{print $4}' /proc/loadavg | cut -d/ -f2)
    printf "${C2}LOAD:${C0}      %-20s  Uptime: %s\n\n" "$LOAD" "$(uptime | sed 's/.*up //;s/,  .*//')"

    # ── Top Processes ─────────────────────────────────────────
    printf "${C3}── Top Processes ───────────────────────────────────${C0}\n"
    printf "  ${C4}%-6s %-6s %-10s %s${C0}\n" "PID" "VSZ(k)" "USER" "COMMAND"
    ps 2>/dev/null | grep -v 'PID\|bit-monitor\|grep' | sort -k3 -rn 2>/dev/null | head -8 | \
        awk 'NF>=4{printf "  %-6s %-6s %-10s %s\n", $1,$3,$2,$NF}'

    # ── Network ───────────────────────────────────────────────
    printf "\n${C3}── Network ─────────────────────────────────────────${C0}\n"
    for IF in eth0 lo; do
        IP=$(ifconfig "$IF" 2>/dev/null | awk '/inet /{print $2}')
        [ -z "$IP" ] && continue
        RX=$(cat "/sys/class/net/$IF/statistics/rx_bytes" 2>/dev/null || echo 0)
        TX=$(cat "/sys/class/net/$IF/statistics/tx_bytes" 2>/dev/null || echo 0)
        printf "  %-6s %-18s  RX:%6d KB  TX:%6d KB\n" "$IF" "$IP" "$((RX/1024))" "$((TX/1024))"
    done

    # ── Services ──────────────────────────────────────────────
    printf "\n${C3}── Services ────────────────────────────────────────${C0}\n"
    printf "  sshd   %b   httpd  %b   crond  %b\n" \
        "$(svc_badge sshd  /var/run/sshd.pid)" \
        "$(svc_badge httpd '')" \
        "$(svc_badge crond '')"

    sleep "$INTERVAL"
done
