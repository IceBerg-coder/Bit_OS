#!/bin/sh
# bit-firewall: iptables TUI for BitOS
# Usage: bit-firewall [status|allow|block|reset|list|ssh-protect]

RED='\033[0;31m'; GRN='\033[0;32m'; YEL='\033[1;33m'; BLU='\033[1;34m'; NC='\033[0m'

fw_status() {
    echo -e "${BLU}=== Firewall Status ===${NC}"
    echo -e "${YEL}INPUT chain:${NC}"
    iptables -L INPUT -n --line-numbers -v 2>/dev/null | awk '
        NR==1{print; next}
        NR==2{print; next}
        /ACCEPT/{printf "\033[0;32m"; print; printf "\033[0m"; next}
        /DROP|REJECT/{printf "\033[0;31m"; print; printf "\033[0m"; next}
        {print}
    '
    echo ""
    POLICY=$(iptables -L INPUT 2>/dev/null | head -1 | grep -o 'policy [A-Z]*')
    echo -e "${YEL}Policy: ${NC}$POLICY"
    RULE_COUNT=$(iptables -L INPUT -n 2>/dev/null | grep -c "^[A-Z]" || echo 0)
    echo -e "${YEL}Total rules: ${NC}$RULE_COUNT"
}

fw_allow() {
    [ -z "$1" ] && echo "Usage: bit-firewall allow <port> [tcp|udp] [comment]" && return 1
    PORT="$1"; PROTO="${2:-tcp}"
    iptables -A INPUT -p "$PROTO" --dport "$PORT" -j ACCEPT
    echo -e "${GRN}[+] Allowed $PROTO port $PORT${NC}"
}

fw_block() {
    [ -z "$1" ] && echo "Usage: bit-firewall block <port> [tcp|udp]" && return 1
    PORT="$1"; PROTO="${2:-tcp}"
    iptables -A INPUT -p "$PROTO" --dport "$PORT" -j DROP
    echo -e "${RED}[-] Blocked $PROTO port $PORT${NC}"
}

fw_del() {
    [ -z "$1" ] && echo "Usage: bit-firewall del <rule_number>" && return 1
    iptables -D INPUT "$1" && echo -e "${YEL}[~] Deleted rule $1${NC}" || echo -e "${RED}[!] Failed to delete rule $1${NC}"
}

fw_reset() {
    echo -n "Reset all firewall rules? (y/N): "
    read -r C; [ "$C" != "y" ] && echo "Aborted." && return 0
    iptables -F INPUT
    iptables -A INPUT -i lo -j ACCEPT
    iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
    iptables -A INPUT -p tcp --dport 22 -m state --state NEW -m recent --set --name SSH
    iptables -A INPUT -p tcp --dport 22 -m state --state NEW -m recent --update --seconds 60 --hitcount 4 --name SSH -j DROP
    iptables -A INPUT -p tcp --dport 22 -j ACCEPT
    iptables -A INPUT -p tcp --dport 23 -j ACCEPT
    iptables -A INPUT -p tcp --dport 80 -j ACCEPT
    iptables -A INPUT -p tcp --dport 443 -j ACCEPT
    iptables -A INPUT -p icmp -m limit --limit 10/s -j ACCEPT
    iptables -A INPUT -j DROP
    echo -e "${GRN}[+] Firewall reset to defaults${NC}"
}

fw_save() {
    iptables-save > /etc/iptables.rules 2>/dev/null
    echo -e "${GRN}[+] Rules saved to /etc/iptables.rules${NC}"
    echo "    Load on boot with: iptables-restore < /etc/iptables.rules"
}

fw_menu() {
    while true; do
        echo ""
        echo -e "${BLU}╔══════════════════════════════╗${NC}"
        echo -e "${BLU}║   BitOS Firewall Manager     ║${NC}"
        echo -e "${BLU}╚══════════════════════════════╝${NC}"
        echo -e "  ${GRN}1)${NC} Show status"
        echo -e "  ${GRN}2)${NC} Allow a port"
        echo -e "  ${GRN}3)${NC} Block a port"
        echo -e "  ${RED}4)${NC} Delete a rule (by number)"
        echo -e "  ${YEL}5)${NC} Reset to defaults"
        echo -e "  ${YEL}6)${NC} Save rules"
        echo -e "  ${RED}q)${NC} Quit"
        echo -n "Choice: "
        read -r OPT
        case "$OPT" in
            1) fw_status ;;
            2) echo -n "Port: "; read -r P; echo -n "Proto [tcp]: "; read -r R; fw_allow "$P" "${R:-tcp}" ;;
            3) echo -n "Port: "; read -r P; echo -n "Proto [tcp]: "; read -r R; fw_block "$P" "${R:-tcp}" ;;
            4) fw_status; echo -n "Rule number to delete: "; read -r N; fw_del "$N" ;;
            5) fw_reset ;;
            6) fw_save ;;
            q|Q) break ;;
            *) echo "Invalid option" ;;
        esac
    done
}

case "$1" in
    status)       fw_status ;;
    allow)        shift; fw_allow "$@" ;;
    block)        shift; fw_block "$@" ;;
    del|delete)   shift; fw_del "$@" ;;
    reset)        fw_reset ;;
    save)         fw_save ;;
    menu|"")      fw_menu ;;
    *)
        echo "Usage: bit-firewall [status|allow|block|del|reset|save|menu]"
        echo "  bit-firewall status        - show all rules"
        echo "  bit-firewall allow 8080    - allow TCP port 8080"
        echo "  bit-firewall block 8080    - block TCP port 8080"
        echo "  bit-firewall del 3         - delete rule #3"
        echo "  bit-firewall reset         - reset to defaults"
        echo "  bit-firewall menu          - interactive TUI" ;;
esac
