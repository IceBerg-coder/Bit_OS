#!/bin/sh
# bit-net: Network utility toolkit for BitOS
C0='\033[0m'; C1='\033[1;32m'; C2='\033[1;34m'; C3='\033[1;31m'; C4='\033[1;33m'; C5='\033[1;36m'

usage() {
    printf "${C1}bit-net${C0} - BitOS Network Toolkit\n\n"
    printf "${C2}Usage:${C0}\n"
    printf "  bit-net get <url>          Download URL content\n"
    printf "  bit-net dns <host>         DNS lookup\n"
    printf "  bit-net ping <host>        Ping host (5 packets)\n"
    printf "  bit-net scan <host>        Scan common ports\n"
    printf "  bit-net status             Show network interfaces\n"
    printf "  bit-net speed              Test download speed\n"
    printf "  bit-net trace <host>       Traceroute to host\n"
}

case "$1" in
    get)
        [ -z "$2" ] && printf "${C3}Usage: bit-net get <url>${C0}\n" && exit 1
        printf "${C2}[*] Fetching: $2${C0}\n"
        wget -q --no-check-certificate -O- "$2" 2>&1
        ;;
    dns)
        [ -z "$2" ] && printf "${C3}Usage: bit-net dns <host>${C0}\n" && exit 1
        printf "${C1}--- DNS Lookup: $2 ---${C0}\n"
        nslookup "$2" 2>/dev/null || printf "${C3}nslookup failed${C0}\n"
        printf "\n${C2}From /etc/resolv.conf:${C0}\n"
        cat /etc/resolv.conf 2>/dev/null
        ;;
    ping)
        [ -z "$2" ] && printf "${C3}Usage: bit-net ping <host>${C0}\n" && exit 1
        printf "${C1}--- Ping: $2 (5 packets) ---${C0}\n"
        ping -c 5 "$2"
        ;;
    scan)
        [ -z "$2" ] && printf "${C3}Usage: bit-net scan <host>${C0}\n" && exit 1
        printf "${C1}--- Port Scan: $2 ---${C0}\n"
        for port in 21 22 23 25 53 80 443 3306 5432 8080; do
            result=$(nc -z -w1 "$2" "$port" 2>/dev/null && echo "OPEN" || echo "closed")
            if [ "$result" = "OPEN" ]; then
                printf "  ${C1}%-6s OPEN${C0}\n" "$port"
            else
                printf "  ${C0}%-6s closed${C0}\n" "$port"
            fi
        done
        ;;
    status)
        printf "${C1}--- Network Interfaces ---${C0}\n"
        ifconfig 2>/dev/null | awk '
            /^[a-zA-Z]/ { iface=$1; flags=$0 }
            /inet /     { printf "  \033[1;32m%-12s\033[0m %s\n", iface, $2 }
        '
        printf "\n${C2}Default route:${C0} "
        route -n 2>/dev/null | awk '/^0\.0\.0\.0/ {print $2}' || echo "none"
        printf "${C2}DNS servers:${C0} "
        awk '/^nameserver/ {printf $2 " "}' /etc/resolv.conf 2>/dev/null; echo
        ;;
    speed)
        printf "${C1}--- Download Speed Test ---${C0}\n"
        printf "${C4}Testing with 1MB from kernel.org...${C0}\n"
        START=$(date +%s%3N)
        wget -q --no-check-certificate -O /dev/null \
            "https://cdn.kernel.org/pub/linux/kernel/v6.x/patch-6.6.1.xz" 2>/dev/null
        END=$(date +%s%3N)
        ELAPSED=$(( END - START ))
        printf "${C1}Completed in ${ELAPSED}ms${C0}\n"
        ;;
    trace)
        [ -z "$2" ] && printf "${C3}Usage: bit-net trace <host>${C0}\n" && exit 1
        printf "${C1}--- Traceroute: $2 ---${C0}\n"
        traceroute "$2" 2>/dev/null || printf "${C3}traceroute not available${C0}\n"
        ;;
    ""|--help|-h)
        usage
        ;;
    *)
        printf "${C3}Unknown command: $1${C0}\n\n"
        usage
        ;;
esac
