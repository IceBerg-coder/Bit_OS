#!/bin/sh
# bit-log: Log viewer and manager for BitOS
C0='\033[0m'; C1='\033[1;32m'; C2='\033[1;34m'; C3='\033[1;33m'; CR='\033[1;31m'; C4='\033[1;36m'

LOGDIR="/var/log"
LOGS="messages kern.log auth.log cron.log httpd.log uptime.log"

usage() {
    printf "${C2}bit-log${C0} - BitOS log viewer\n"
    printf "  ${C4}bit-log${C0}              List all logs with sizes\n"
    printf "  ${C4}bit-log <name>${C0}       Show last 30 lines of a log\n"
    printf "  ${C4}bit-log tail <name>${C0}  Follow log in real-time (Ctrl+C to stop)\n"
    printf "  ${C4}bit-log clear <name>${C0} Clear a log file\n"
    printf "  ${C4}bit-log clear all${C0}    Clear all logs\n"
}

case "$1" in
    "")
        printf "${C2}========================================${C0}\n"
        printf "${C2}         BitOS Log Manager              ${C0}\n"
        printf "${C2}========================================${C0}\n"
        printf "${C4}%-20s %8s  %s${C0}\n" "Log File" "Size" "Last Entry"
        printf "${C3}%-20s %8s  %s${C0}\n" "--------------------" "--------" "----------"
        for log in $LOGS; do
            path="$LOGDIR/$log"
            if [ -f "$path" ]; then
                size=$(wc -c < "$path")
                last=$(tail -1 "$path" 2>/dev/null | cut -c1-50)
                printf "  %-18s %6d B  %s\n" "$log" "$size" "$last"
            else
                printf "  ${C3}%-18s  (empty)${C0}\n" "$log"
            fi
        done
        printf "${C2}========================================${C0}\n"
        printf "Run: ${C4}bit-log <name>${C0} to view a log\n"
        ;;
    "tail")
        [ -z "$2" ] && usage && exit 1
        path="$LOGDIR/$2"
        [ ! -f "$path" ] && printf "${CR}Log not found: $path${C0}\n" && exit 1
        printf "${C1}=== Following $path (Ctrl+C to stop) ===${C0}\n"
        tail -f "$path"
        ;;
    "clear")
        if [ "$2" = "all" ]; then
            printf "${CR}Clear ALL logs? (y/N): ${C0}"
            read ans
            [ "$ans" != "y" ] && echo "Aborted." && exit 0
            for log in $LOGS; do
                [ -f "$LOGDIR/$log" ] && : > "$LOGDIR/$log" && printf "  Cleared: %s\n" "$log"
            done
            printf "${C1}All logs cleared.${C0}\n"
        else
            [ -z "$2" ] && usage && exit 1
            path="$LOGDIR/$2"
            [ ! -f "$path" ] && printf "${CR}Log not found: $path${C0}\n" && exit 1
            : > "$path"
            printf "${C1}Cleared: $path${C0}\n"
        fi
        ;;
    *)
        path="$LOGDIR/$1"
        [ ! -f "$path" ] && printf "${CR}Log not found: $path${C0}\n\n" && usage && exit 1
        printf "${C2}=== Last 30 lines of $path ===${C0}\n"
        tail -30 "$path"
        printf "${C2}====================================${C0}\n"
        printf "Lines: $(wc -l < "$path")  Size: $(wc -c < "$path") bytes\n"
        ;;
esac
