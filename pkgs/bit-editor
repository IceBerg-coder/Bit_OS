#!/bin/sh
# bit-editor: Text file editor for BitOS
C0='\033[0m'; C1='\033[1;32m'; C2='\033[1;34m'; C3='\033[1;31m'; C4='\033[1;33m'

usage() {
    printf "${C1}bit-editor${C0} - BitOS Text Editor\n\n"
    printf "${C2}Usage:${C0}\n"
    printf "  bit-editor <file>          Edit or create a file\n"
    printf "  bit-editor view <file>     View file (read-only)\n"
    printf "  bit-editor new <file>      Create new file\n"
    printf "  bit-editor list [dir]      List text files in directory\n"
    printf "\n${C4}Editor keys: i=insert  Esc=cmd  :w=save  :q=quit  :wq=save+quit${C0}\n"
}

case "$1" in
    view)
        [ -z "$2" ] && printf "${C3}Usage: bit-editor view <file>${C0}\n" && exit 1
        [ ! -f "$2" ] && printf "${C3}File not found: $2${C0}\n" && exit 1
        more "$2"
        ;;
    new)
        [ -z "$2" ] && printf "${C3}Usage: bit-editor new <file>${C0}\n" && exit 1
        [ -f "$2" ] && printf "${C4}Warning: $2 already exists. Opening for edit.${C0}\n"
        vi "$2"
        ;;
    list)
        DIR="${2:-.}"
        printf "${C1}Text files in $DIR:${C0}\n"
        find "$DIR" -maxdepth 1 -type f 2>/dev/null | while read f; do
            SIZE=$(wc -c < "$f" 2>/dev/null)
            LINES=$(wc -l < "$f" 2>/dev/null)
            printf "  ${C2}%-30s${C0} %5s bytes  %4s lines\n" "$(basename $f)" "$SIZE" "$LINES"
        done
        ;;
    ""|--help|-h)
        usage
        ;;
    *)
        # Direct file edit
        FILE="$1"
        if [ ! -f "$FILE" ]; then
            printf "${C4}[?] File '$FILE' does not exist. Create it? [y/N] ${C0}"
            read ans
            [ "$ans" != "y" ] && [ "$ans" != "Y" ] && exit 0
        fi
        vi "$FILE"
        if [ -f "$FILE" ]; then
            LINES=$(wc -l < "$FILE")
            SIZE=$(wc -c < "$FILE")
            printf "${C1}[✓] Saved: $FILE ($LINES lines, $SIZE bytes)${C0}\n"
        fi
        ;;
esac
