#!/bin/sh
# bit-netinfo: Network diagnostics tool for BitOS
C0='\033[0m'; C1='\033[1;32m'; C2='\033[1;34m'; C3='\033[1;33m'; C4='\033[1;31m'

printf "${C1}========================================${C0}\n"
printf "${C1}       BitOS Network Information        ${C0}\n"
printf "${C1}========================================${C0}\n"

# Interfaces
printf "${C2}[ Interfaces ]${C0}\n"
ifconfig 2>/dev/null | awk '
  /^[a-z]/ { iface=$1; mac="" }
  /HWaddr/  { mac=$NF }
  /inet /   { ip=$2; mask=$4; print "  " iface "\t IP: " ip "\t Mask: " mask }
  /Link encap/ { }
' 
ifconfig 2>/dev/null | grep -E '^(eth|lo|wlan)' | while read line; do
    dev=$(echo "$line" | awk '{print $1}')
    rx=$(cat /sys/class/net/$dev/statistics/rx_bytes 2>/dev/null)
    tx=$(cat /sys/class/net/$dev/statistics/tx_bytes 2>/dev/null)
    [ -n "$rx" ] && printf "  %-8s RX: %s bytes  TX: %s bytes\n" "$dev" "$rx" "$tx"
done

printf "${C3}----------------------------------------${C0}\n"

# Default route / gateway
printf "${C2}[ Routing Table ]${C0}\n"
route -n 2>/dev/null | grep -v '^Kernel\|^Destination' | \
  awk '{printf "  %-18s %-18s %-8s %s\n", $1, $2, $3, $8}'

printf "${C3}----------------------------------------${C0}\n"

# DNS
printf "${C2}[ DNS Servers ]${C0}\n"
grep nameserver /etc/resolv.conf 2>/dev/null | awk '{print "  " $2}' || echo "  (none)"

printf "${C3}----------------------------------------${C0}\n"

# Connectivity test
printf "${C2}[ Connectivity Test ]${C0}\n"
GW=$(route -n 2>/dev/null | grep '^0\.0\.0\.0' | awk '{print $2}' | head -1)
if [ -n "$GW" ]; then
    if ping -c 1 -W 2 "$GW" >/dev/null 2>&1; then
        printf "  Gateway ${C1}%-16s [OK]${C0}\n" "$GW"
    else
        printf "  Gateway ${C4}%-16s [FAIL]${C0}\n" "$GW"
    fi
fi
if ping -c 1 -W 3 8.8.8.8 >/dev/null 2>&1; then
    printf "  ${C1}Internet (8.8.8.8)    [OK]${C0}\n"
else
    printf "  ${C4}Internet (8.8.8.8)    [FAIL]${C0}\n"
fi
if wget -q --spider --no-check-certificate https://github.com 2>/dev/null; then
    printf "  ${C1}GitHub HTTPS          [OK]${C0}\n"
else
    printf "  ${C4}GitHub HTTPS          [FAIL]${C0}\n"
fi

printf "${C3}----------------------------------------${C0}\n"

# Open ports
printf "${C2}[ Listening Ports ]${C0}\n"
netstat -tlnp 2>/dev/null | grep LISTEN | awk '{printf "  %-25s %s\n", $4, $NF}' || \
  cat /proc/net/tcp 2>/dev/null | awk 'NR>1 {
    split($2,a,":"); port=strtonum("0x"a[2]);
    if ($4=="0A") printf "  TCP 0.0.0.0:%d\n", port
  }' | sort -t: -k2 -n | uniq

printf "${C1}========================================${C0}\n"
