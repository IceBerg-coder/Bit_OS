# Build output - large binaries
output/
build/

# Downloaded source tarballs
src/*.tar.xz
src/*.tar.bz2
src/*.tar.gz
src/musl-packages/

# musl cross-compile toolchain (built to $HOME/musl-cross by default)
musl-cross/

# Kernel and busybox build artifacts (keep source directories)
src/linux-*/vmlinux
src/linux-*/vmlinuz
src/busybox-*/_install/

# Storage images
*.img
*.iso
pkgs/keys/signing_key.pem
